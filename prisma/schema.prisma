generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id           String   @id @db.Uuid
  displayName  String   @map("display_name")
  primaryEmail String?  @map("primary_email")
  givenName    String?  @map("given_name")
  familyName   String?  @map("family_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("person")
  @@index([primaryEmail], map: "person_primary_email_idx")
}

model PersonIdentityLink {
  id        String   @id @db.Uuid
  personId  String   @map("person_id")
  issuer    String
  subject   String
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("person_identity_link")
  @@unique([issuer, subject], map: "person_identity_link_issuer_subject_uidx")
  @@index([email], map: "person_identity_link_email_idx")
  @@index([personId], map: "person_identity_link_person_id_idx")
}

model Member {
  id                String    @id @db.Uuid
  personId          String    @unique @map("person_id")
  memberNumber      String?   @map("member_number")
  membershipClassId String?   @map("membership_class_id")
  status            String
  admittedAt        DateTime? @map("admitted_at")
  endedAt           DateTime? @map("ended_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("member")
}

model GovernanceBody {
  id          String   @id @db.Uuid
  code        String   @unique
  name        String
  description String?
  bodyType    String   @map("body_type")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  offices     Office[]

  @@map("governance_body")
}

model Office {
  id               String    @id @db.Uuid
  code             String    @unique
  name             String
  description      String?
  governanceBodyId String?   @map("governance_body_id") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  governanceBody   GovernanceBody? @relation(fields: [governanceBodyId], references: [id], onDelete: SetNull)
  officeHolders    OfficeHolder[]

  @@map("office")
}

model OfficeHolder {
  id          String    @id @db.Uuid
  officeId    String    @map("office_id") @db.Uuid
  personId    String    @map("person_id")
  appointedAt DateTime? @map("appointed_at")
  startedAt   DateTime  @map("started_at")
  endedAt     DateTime? @map("ended_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  office      Office    @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@map("office_holder")
  @@index([personId], map: "office_holder_person_id_idx")
  @@index([officeId], map: "office_holder_office_id_idx")
}

model Role {
  id          String   @id @db.Uuid
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  assignments RoleAssignment[]

  @@map("role")
}

model RoleAssignment {
  id         String    @id @db.Uuid
  roleId     String    @map("role_id") @db.Uuid
  personId   String    @map("person_id")
  scopeType  String?   @map("scope_type")
  scopeId    String?   @map("scope_id")
  expiresAt  DateTime? @map("expires_at")
  assignedAt DateTime  @map("assigned_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("role_assignment")
  @@index([personId], map: "role_assignment_person_id_idx")
  @@index([roleId], map: "role_assignment_role_id_idx")
}

model Delegation {
  id                  String    @id @db.Uuid
  delegatorPersonId   String    @map("delegator_person_id")
  delegatePersonId    String    @map("delegate_person_id")
  scopeType           String?   @map("scope_type")
  scopeId             String?   @map("scope_id")
  authorityGrantCodes String[]  @default([]) @map("authority_grant_codes")
  reason              String?
  effectiveAt         DateTime  @map("effective_at")
  expiresAt           DateTime? @map("expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@map("delegation")
  @@index([delegatePersonId], map: "delegation_delegate_person_id_idx")
}

model GovernanceRule {
  id              String   @id @db.Uuid
  code            String   @unique
  name            String
  ruleType        String   @map("rule_type")
  description     String?
  sourceReference String?  @map("source_reference")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  versions        RuleVersion[]

  @@map("governance_rule")
  @@index([ruleType], map: "governance_rule_rule_type_idx")
}

model RuleVersion {
  id               String    @id @db.Uuid
  governanceRuleId String    @map("governance_rule_id") @db.Uuid
  versionLabel     String    @map("version_label")
  effectiveFrom    DateTime  @map("effective_from")
  effectiveTo      DateTime? @map("effective_to")
  status           String
  parametersJson   String?   @map("parameters_json")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  governanceRule   GovernanceRule   @relation(fields: [governanceRuleId], references: [id], onDelete: Cascade)
  scopes           RuleVersionScope[]

  @@map("rule_version")
  @@index([governanceRuleId], map: "rule_version_governance_rule_id_idx")
  @@index([status, effectiveFrom], map: "rule_version_status_effective_from_idx")
}

model RuleVersionScope {
  id            String   @id @db.Uuid
  ruleVersionId String   @map("rule_version_id") @db.Uuid
  scopeType     String   @map("scope_type")
  scopeId       String?  @map("scope_id")
  createdAt     DateTime @default(now()) @map("created_at")

  ruleVersion   RuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Cascade)

  @@map("rule_version_scope")
  @@index([ruleVersionId], map: "rule_version_scope_rule_version_id_idx")
  @@index([scopeType, scopeId], map: "rule_version_scope_scope_idx")
}

model Proposal {
  id               String    @id @db.Uuid
  proposalNumber   String?   @map("proposal_number")
  title            String
  summary          String?
  proposalType     String    @map("proposal_type")
  currentStage     String    @map("current_stage")
  proposerPersonId String?   @map("proposer_person_id")
  proposerMemberId String?   @map("proposer_member_id")
  currentVersionId String?   @unique @map("current_version_id")
  submittedAt      DateTime? @map("submitted_at")
  withdrawnAt      DateTime? @map("withdrawn_at")
  rejectedAt       DateTime? @map("rejected_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  versions         ProposalVersion[]
  ballots          Ballot[]

  @@map("proposal")
  @@index([currentStage], map: "proposal_current_stage_idx")
  @@index([proposalType], map: "proposal_proposal_type_idx")
  @@index([createdAt], map: "proposal_created_at_idx")
}

model ProposalVersion {
  id                String   @id @db.Uuid
  proposalId        String   @map("proposal_id") @db.Uuid
  versionNumber     Int      @map("version_number")
  titleSnapshot     String   @map("title_snapshot")
  bodyMarkdown      String   @map("body_markdown")
  changeSummary     String?  @map("change_summary")
  createdByPersonId String   @map("created_by_person_id")
  createdAt         DateTime @default(now()) @map("created_at")

  proposal          Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_version")
  @@unique([proposalId, versionNumber], map: "proposal_version_proposal_id_version_number_uidx")
  @@index([proposalId], map: "proposal_version_proposal_id_idx")
}

model Ballot {
  id                String    @id @db.Uuid
  proposalId        String?   @map("proposal_id") @db.Uuid
  title             String
  description       String?
  state             String
  scheduledOpenAt   DateTime? @map("scheduled_open_at")
  openedAt          DateTime? @map("opened_at")
  scheduledCloseAt  DateTime? @map("scheduled_close_at")
  closedAt          DateTime? @map("closed_at")
  cancelledAt       DateTime? @map("cancelled_at")
  createdByPersonId String    @map("created_by_person_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  proposal          Proposal?                   @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  eligibility       BallotEligibilitySnapshot[]
  votes             Vote[]
  tally             VoteTally?
  certifications    CertificationRecord[]

  @@map("ballot")
  @@index([state], map: "ballot_state_idx")
  @@index([proposalId], map: "ballot_proposal_id_idx")
  @@index([createdAt], map: "ballot_created_at_idx")
}

model BallotEligibilitySnapshot {
  id                String   @id @db.Uuid
  ballotId          String   @map("ballot_id") @db.Uuid
  memberId          String   @map("member_id")
  eligibilityStatus String   @map("eligibility_status")
  reason            String?
  snapshotAt        DateTime @map("snapshot_at")
  createdAt         DateTime @default(now()) @map("created_at")

  ballot            Ballot   @relation(fields: [ballotId], references: [id], onDelete: Cascade)

  @@map("ballot_eligibility_snapshot")
  @@index([ballotId], map: "ballot_eligibility_snapshot_ballot_id_idx")
  @@index([ballotId, memberId], map: "ballot_eligibility_snapshot_ballot_member_idx")
}

model Vote {
  id         String   @id @db.Uuid
  ballotId   String   @map("ballot_id") @db.Uuid
  memberId   String   @map("member_id")
  personId   String?  @map("person_id")
  choice     String
  castAt     DateTime @map("cast_at")
  recordedAt DateTime @map("recorded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  ballot     Ballot   @relation(fields: [ballotId], references: [id], onDelete: Cascade)

  @@map("vote")
  @@index([ballotId], map: "vote_ballot_id_idx")
  @@unique([ballotId, memberId], map: "vote_ballot_id_member_id_uidx")
}

model VoteTally {
  id            String   @id @db.Uuid
  ballotId      String   @unique @map("ballot_id") @db.Uuid
  yesCount      Int      @map("yes_count")
  noCount       Int      @map("no_count")
  abstainCount  Int      @map("abstain_count")
  totalCount    Int      @map("total_count")
  quorumMet     Boolean  @map("quorum_met")
  thresholdMet  Boolean  @map("threshold_met")
  computedAt    DateTime @map("computed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  ballot        Ballot   @relation(fields: [ballotId], references: [id], onDelete: Cascade)

  @@map("vote_tally")
}

model CertificationRecord {
  id                         String    @id @db.Uuid
  ballotId                   String    @map("ballot_id") @db.Uuid
  status                     String
  certifiedByPersonId        String?   @map("certified_by_person_id")
  certifiedAt                DateTime? @map("certified_at")
  rejectedAt                 DateTime? @map("rejected_at")
  notes                      String?
  quorumRuleVersionId        String    @map("quorum_rule_version_id")
  thresholdRuleVersionId     String    @map("threshold_rule_version_id")
  certificationRuleVersionId String?   @map("certification_rule_version_id")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  ballot                     Ballot    @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  ratifications              RatificationRecord[]

  @@map("certification_record")
  @@index([ballotId], map: "certification_record_ballot_id_idx")
}

model RatificationRecord {
  id                    String    @id @db.Uuid
  proposalId            String    @map("proposal_id") @db.Uuid
  certificationRecordId String?   @map("certification_record_id") @db.Uuid
  status                String
  ratifiedByPersonId    String?   @map("ratified_by_person_id")
  ratifiedAt            DateTime? @map("ratified_at")
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  certificationRecord   CertificationRecord? @relation(fields: [certificationRecordId], references: [id], onDelete: SetNull)

  @@map("ratification_record")
  @@index([proposalId], map: "ratification_record_proposal_id_idx")
}

model OfficialRecord {
  id               String    @id @db.Uuid
  recordType       String    @map("record_type")
  title            String
  summary          String?
  sourceEntityType String    @map("source_entity_type")
  sourceEntityId   String    @map("source_entity_id")
  status           String
  officializedAt   DateTime? @map("officialized_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  versions         RecordVersion[]
  gazetteEntries   GazetteEntry[]

  @@map("official_record")
  @@index([recordType], map: "official_record_record_type_idx")
  @@index([status], map: "official_record_status_idx")
  @@index([sourceEntityType, sourceEntityId], map: "official_record_source_entity_idx")
}

model RecordVersion {
  id               String    @id @db.Uuid
  officialRecordId String    @map("official_record_id") @db.Uuid
  versionNumber    Int       @map("version_number")
  bodyMarkdown     String    @map("body_markdown")
  changeSummary    String?   @map("change_summary")
  createdByPersonId String?  @map("created_by_person_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  officialRecord   OfficialRecord @relation(fields: [officialRecordId], references: [id], onDelete: Cascade)

  @@map("record_version")
  @@unique([officialRecordId, versionNumber], map: "record_version_record_id_version_number_uidx")
  @@index([officialRecordId], map: "record_version_record_id_idx")
}

model GazetteIssue {
  id                String    @id @db.Uuid
  issueNumber       String?   @map("issue_number")
  title             String
  publicationState  String    @map("publication_state")
  scheduledFor      DateTime? @map("scheduled_for")
  publishedAt       DateTime? @map("published_at")
  createdByPersonId String    @map("created_by_person_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  entries           GazetteEntry[]

  @@map("gazette_issue")
  @@index([publicationState], map: "gazette_issue_publication_state_idx")
  @@index([createdAt], map: "gazette_issue_created_at_idx")
}

model GazetteEntry {
  id               String    @id @db.Uuid
  gazetteIssueId   String    @map("gazette_issue_id") @db.Uuid
  officialRecordId String    @map("official_record_id") @db.Uuid
  titleSnapshot    String    @map("title_snapshot")
  summarySnapshot  String?   @map("summary_snapshot")
  publicationOrder Int       @map("publication_order")
  publishedAt      DateTime? @map("published_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  gazetteIssue     GazetteIssue   @relation(fields: [gazetteIssueId], references: [id], onDelete: Cascade)
  officialRecord   OfficialRecord @relation(fields: [officialRecordId], references: [id], onDelete: Cascade)

  @@map("gazette_entry")
  @@index([gazetteIssueId], map: "gazette_entry_issue_id_idx")
  @@unique([gazetteIssueId, publicationOrder], map: "gazette_entry_issue_publication_order_uidx")
}

model AuditEvent {
  id                  String   @id @db.Uuid
  actionType          String   @map("action_type")
  entityType          String   @map("entity_type")
  entityId            String   @map("entity_id")
  actorPersonId       String?  @map("actor_person_id")
  authoritySourceType String?  @map("authority_source_type")
  authoritySourceId   String?  @map("authority_source_id")
  ruleVersionIds      String[] @default([]) @map("rule_version_ids")
  summary             String?
  metadataJson        String?  @map("metadata_json")
  occurredAt          DateTime @map("occurred_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("audit_event")
  @@index([occurredAt], map: "audit_event_occurred_at_idx")
  @@index([actionType], map: "audit_event_action_type_idx")
  @@index([entityType, entityId], map: "audit_event_entity_idx")
  @@index([actorPersonId], map: "audit_event_actor_person_id_idx")
}

model IdempotencyRecord {
  id             String   @id @db.Uuid
  idempotencyKey String   @map("idempotency_key")
  actorPersonId  String   @map("actor_person_id")
  operationName  String   @map("operation_name")
  requestHash    String   @map("request_hash")
  responseJson   String   @map("response_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("idempotency_record")
  @@unique([actorPersonId, operationName, idempotencyKey], map: "idempotency_record_actor_operation_key_uidx")
  @@index([createdAt], map: "idempotency_record_created_at_idx")

}

enum MembershipApplicationState {
  draft
  submitted
  under_review
  returned_for_revision
  approved
  rejected
  withdrawn
}

enum MembershipState {
  pending_activation
  active
  suspended
  ended
}

enum EntityStatus {
  draft
  active
  inactive
  archived
}

enum ProposalState {
  draft
  submitted
  admissibility_review
  admitted
  rejected
  amendment_window
  scheduled
  voting_open
  voting_closed
  certified
  ratified
  failed
  withdrawn
  published
  archived
}

enum AmendmentState {
  draft
  submitted
  under_review
  accepted
  rejected
  withdrawn
  incorporated
  archived
}

enum VoteState {
  configured
  open
  closed
  tallied
  certified
  voided
}

enum OutcomeState {
  pending
  certified
  ratified
  failed
  withdrawn
  superseded
  archived
}

enum CertificationState {
  pending
  under_review
  certified
  rejected
  superseded
}

enum RecordStatus {
  draft
  under_review
  official
  published
  superseded
  archived
}

enum PublicationState {
  not_publishable
  eligible
  scheduled
  published
  withdrawn
  corrected
  superseded
  archived
}

enum PublicationScope {
  public
  members_only
  internal_staff
  restricted_governance
  private_unpublished
}

enum PublicationChannel {
  website_page
  register
  gazette
  member_portal
  internal_dashboard
  email
  document_download
}

enum PolicyState {
  draft
  active
  superseded
  archived
}

enum OfficeAssignmentState {
  vacant
  nominated
  under_review
  appointed
  active
  ended
  removed
}

enum SessionState {
  draft
  scheduled
  in_session
  concluded
  archived
}

enum AuditActionResult {
  success
  denied
  failure
}

model User {
  id                String                       @id @default(cuid())
  externalAuthId    String?                      @unique
  email             String?                      @unique
  displayName       String?
  givenName         String?
  familyName        String?
  isSystemActor     Boolean                      @default(false)
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  roleAssignments   UserRoleAssignment[]
  membershipApps    MembershipApplication[]
  memberships       MembershipRecord[]
  bodyMemberships   GovernanceBodyMembership[]
  officeAssignments OfficeAssignment[]
  auditEvents       AuditEvent[]                 @relation("AuditActor")
  certifications    Certification[]              @relation("CertificationActor")
  createdVersions   RecordVersion[]              @relation("RecordVersionCreator")

  @@index([email])
  @@index([externalAuthId])
}

model ApplicationRole {
  id          String               @id @default(cuid())
  key         String               @unique
  name        String
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  assignments UserRoleAssignment[]
}

model UserRoleAssignment {
  id        String          @id @default(cuid())
  userId    String
  roleId    String
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ApplicationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
}

model MembershipApplication {
  id                       String                     @id @default(cuid())
  applicantUserId          String
  state                    MembershipApplicationState
  membershipClassRequested String?
  summary                  String?
  submittedAt              DateTime?
  reviewedAt               DateTime?
  decisionAt               DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  applicant                User                       @relation(fields: [applicantUserId], references: [id], onDelete: Restrict)
  reviews                  MembershipApplicationReview[]
  membershipDecision       MembershipDecision?
  auditEvents              AuditEvent[]               @relation("AuditMembershipApplication")

  @@index([applicantUserId])
  @@index([state])
}

model MembershipApplicationReview {
  id             String                 @id @default(cuid())
  applicationId  String
  reviewerUserId String
  reviewState    String
  notes          String?
  createdAt      DateTime               @default(now())

  application    MembershipApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer       User                   @relation(fields: [reviewerUserId], references: [id], onDelete: Restrict)

  @@index([applicationId])
  @@index([reviewerUserId])
}

model MembershipDecision {
  id             String                 @id @default(cuid())
  applicationId  String                 @unique
  decidedByUserId String?
  decisionCode   String
  reason         String?
  decidedAt      DateTime               @default(now())
  createdAt      DateTime               @default(now())

  application    MembershipApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  decidedBy      User?                  @relation(fields: [decidedByUserId], references: [id], onDelete: SetNull)
  membership     MembershipRecord?

  @@index([decisionCode])
}

model MembershipRecord {
  id              String               @id @default(cuid())
  userId          String
  decisionId      String?              @unique
  state           MembershipState
  membershipClass String?
  effectiveAt     DateTime?
  endedAt         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  decision        MembershipDecision?  @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  statusEvents    MembershipStatusEvent[]

  @@index([userId])
  @@index([state])
}

model MembershipStatusEvent {
  id            String           @id @default(cuid())
  membershipId  String
  fromState     MembershipState?
  toState       MembershipState
  reason        String?
  actedByUserId String?
  createdAt     DateTime         @default(now())

  membership    MembershipRecord @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  actedBy       User?            @relation(fields: [actedByUserId], references: [id], onDelete: SetNull)

  @@index([membershipId])
}

model GovernanceBody {
  id              String                    @id @default(cuid())
  slug            String                    @unique
  name            String
  description     String?
  status          EntityStatus
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  offices         Office[]
  memberships     GovernanceBodyMembership[]
  sessions        GovernanceSession[]
  proposals       Proposal[]

  @@index([status])
}

model GovernanceBodyMembership {
  id           String          @id @default(cuid())
  bodyId        String
  userId        String
  roleLabel     String?
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime        @default(now())

  body          GovernanceBody  @relation(fields: [bodyId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([bodyId])
  @@index([userId])
}

model Office {
  id              String              @id @default(cuid())
  bodyId           String?
  slug            String              @unique
  name            String
  description     String?
  status          EntityStatus
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  body            GovernanceBody?     @relation(fields: [bodyId], references: [id], onDelete: SetNull)
  assignments     OfficeAssignment[]

  @@index([bodyId])
  @@index([status])
}

model OfficeAssignment {
  id              String                 @id @default(cuid())
  officeId         String
  userId           String
  state           OfficeAssignmentState
  startsAt        DateTime?
  endsAt          DateTime?
  appointedAt     DateTime?
  removedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  office          Office                 @relation(fields: [officeId], references: [id], onDelete: Restrict)
  user            User                   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([officeId])
  @@index([userId])
  @@index([state])
}

model GovernanceSession {
  id                String           @id @default(cuid())
  bodyId             String?
  title             String
  description       String?
  scheduledStartAt  DateTime?
  scheduledEndAt    DateTime?
  state             SessionState
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  body              GovernanceBody?  @relation(fields: [bodyId], references: [id], onDelete: SetNull)
  agendaItems       AgendaItem[]
  proposals         Proposal[]

  @@index([bodyId])
  @@index([state])
}

model AgendaItem {
  id           String             @id @default(cuid())
  sessionId     String
  proposalId    String?
  title        String
  description  String?
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  session      GovernanceSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposal     Proposal?          @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([proposalId])
}

model Proposal {
  id             String         @id @default(cuid())
  bodyId          String?
  sessionId       String?
  ruleVersionId   String?
  title          String
  summary        String?
  state          ProposalState
  createdByUserId String?
  submittedAt    DateTime?
  admittedAt     DateTime?
  votingOpenedAt DateTime?
  votingClosedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  body           GovernanceBody?    @relation(fields: [bodyId], references: [id], onDelete: SetNull)
  session        GovernanceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  ruleVersion    PolicyVersion?     @relation(fields: [ruleVersionId], references: [id], onDelete: SetNull)
  amendments     Amendment[]
  votes          Vote[]
  outcomes       Outcome[]
  records        Record[]           @relation("ProposalRecords")

  @@index([bodyId])
  @@index([sessionId])
  @@index([ruleVersionId])
  @@index([state])
}

model Amendment {
  id              String          @id @default(cuid())
  proposalId       String
  title           String
  summary         String?
  state           AmendmentState
  createdByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  proposal        Proposal        @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([state])
}

model Vote {
  id             String       @id @default(cuid())
  proposalId      String
  ruleVersionId   String?
  state          VoteState
  opensAt        DateTime?
  closesAt       DateTime?
  talliedAt      DateTime?
  certifiedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  proposal       Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  ruleVersion    PolicyVersion? @relation(fields: [ruleVersionId], references: [id], onDelete: SetNull)
  ballots        Ballot[]
  outcome        Outcome?

  @@index([proposalId])
  @@index([ruleVersionId])
  @@index([state])
}

model Ballot {
  id             String    @id @default(cuid())
  voteId          String
  voterUserId     String
  ballotValue    String
  castAt         DateTime  @default(now())

  vote           Vote      @relation(fields: [voteId], references: [id], onDelete: Cascade)
  voter          User      @relation(fields: [voterUserId], references: [id], onDelete: Restrict)

  @@unique([voteId, voterUserId])
  @@index([voteId])
  @@index([voterUserId])
}

model Outcome {
  id               String            @id @default(cuid())
  proposalId        String
  voteId            String?           @unique
  certificationId   String?           @unique
  ruleVersionId     String?
  state            OutcomeState
  resultCode       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  proposal         Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  vote             Vote?             @relation(fields: [voteId], references: [id], onDelete: SetNull)
  certification    Certification?    @relation(fields: [certificationId], references: [id], onDelete: SetNull)
  ruleVersion      PolicyVersion?    @relation(fields: [ruleVersionId], references: [id], onDelete: SetNull)

  @@index([proposalId])
  @@index([ruleVersionId])
  @@index([state])
}

model Certification {
  id               String             @id @default(cuid())
  state            CertificationState
  scopeType        String
  scopeId          String
  certifiedByUserId String?
  basis            String?
  notes            String?
  certifiedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  certifiedBy      User?              @relation("CertificationActor", fields: [certifiedByUserId], references: [id], onDelete: SetNull)
  recordVersions   RecordVersion[]
  outcome          Outcome?

  @@index([scopeType, scopeId])
  @@index([state])
}

model Record {
  id                String          @id @default(cuid())
  recordType        String
  status            RecordStatus
  sourceEntityType  String?
  sourceEntityId    String?
  currentVersionId  String?         @unique
  supersededById    String?
  archivedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  currentVersion    RecordVersion?  @relation("CurrentRecordVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions          RecordVersion[] @relation("AllRecordVersions")
  publications      Publication[]
  supersededBy      Record?         @relation("RecordSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes        Record[]        @relation("RecordSupersession")
  proposal          Proposal[]      @relation("ProposalRecords")

  @@index([recordType])
  @@index([status])
  @@index([sourceEntityType, sourceEntityId])
}

model RecordVersion {
  id               String          @id @default(cuid())
  recordId         String
  versionNumber    Int
  status           RecordStatus
  title            String?
  summary          String?
  contentMarkdown  String?
  payloadJson      Json?
  contentHash      String?
  changeSummary    String?
  certificationId  String?
  createdByUserId  String?
  createdAt        DateTime        @default(now())

  record           Record          @relation("AllRecordVersions", fields: [recordId], references: [id], onDelete: Cascade)
  certification    Certification?  @relation(fields: [certificationId], references: [id], onDelete: SetNull)
  createdBy        User?           @relation("RecordVersionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  currentForRecord Record?         @relation("CurrentRecordVersion")

  @@unique([recordId, versionNumber])
  @@index([recordId])
  @@index([status])
}

model Publication {
  id               String             @id @default(cuid())
  recordId         String?
  recordVersionId  String?
  state            PublicationState
  scope            PublicationScope
  channel          PublicationChannel
  effectiveAt      DateTime?
  publishedAt      DateTime?
  withdrawnAt      DateTime?
  createdByUserId  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  record           Record?            @relation(fields: [recordId], references: [id], onDelete: SetNull)
  recordVersion    RecordVersion?     @relation(fields: [recordVersionId], references: [id], onDelete: SetNull)
  createdBy        User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([recordVersionId])
  @@index([state])
  @@index([scope])
  @@index([channel])
}

model PolicyDefinition {
  id            String          @id @default(cuid())
  key           String          @unique
  name          String
  description   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  versions      PolicyVersion[]
}

model PolicyVersion {
  id            String          @id @default(cuid())
  policyId       String
  version       Int
  state         PolicyState
  payloadJson   Json
  effectiveAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  policy        PolicyDefinition @relation(fields: [policyId], references: [id], onDelete: Cascade)
  proposals     Proposal[]
  votes         Vote[]
  outcomes      Outcome[]

  @@unique([policyId, version])
  @@index([policyId])
  @@index([state])
}

model AuditEvent {
  id                         String             @id @default(cuid())
  correlationId              String?
  actorUserId                String?
  actionType                 String
  targetType                 String
  targetId                   String?
  result                     AuditActionResult
  reason                     String?
  metadataJson               Json?
  membershipApplicationId    String?
  createdAt                  DateTime           @default(now())

  actor                      User?              @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  membershipApplication      MembershipApplication? @relation("AuditMembershipApplication", fields: [membershipApplicationId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([actionType])
  @@index([targetType, targetId])
  @@index([correlationId])
  @@index([createdAt])
}