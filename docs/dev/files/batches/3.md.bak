rules

notifications

jobs

audit


Mock client

For tests:

import { createMockGovClient, createPaginated } from "@ardtire/gov-client";

const govClient = createMockGovClient({
  proposals: {
    list: async () =>
      createPaginated([
        {
          id: "proposal-1",
          title: "Example Proposal",
          proposalType: "GENERAL",
          currentStage: "DRAFT",
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString(),
        },
      ]),
  },
});

Notes

This package is intended to be used primarily from trusted server-side code in apps/web. Browser-side use should be deliberate and limited to routes that are appropriate to expose directly.

