2. packages/gov-client/src/modules/rules.ts

import { HttpTransport } from "../client/transport";

export interface GovernanceRuleDto {
  id: string;
  code: string;
  name: string;
  ruleType: string;
  description?: string;
  sourceReference?: string;
}

export interface RuleVersionScopeDto {
  scopeType: string;
  scopeId?: string;
}

export interface RuleVersionDto {
  id: string;
  governanceRuleId: string;
  versionLabel: string;
  effectiveFrom: string;
  effectiveTo?: string;
  status: "DRAFT" | "ACTIVE" | "SUPERSEDED" | "RETIRED";
  parameters?: Record<string, unknown>;
  scopes?: RuleVersionScopeDto[];
}

export interface CreateGovernanceRuleRequest {
  code: string;
  name: string;
  ruleType: string;
  description?: string;
  sourceReference?: string;
}

export interface CreateRuleVersionRequest {
  versionLabel: string;
  effectiveFrom: string;
  effectiveTo?: string;
  status: "DRAFT" | "ACTIVE" | "SUPERSEDED" | "RETIRED";
  parameters?: Record<string, unknown>;
  scopes?: RuleVersionScopeDto[];
}

interface SingleEnvelope<T> {
  data: T;
}

interface PlainListEnvelope<T> {
  data: T[];
}

export interface RulesClient {
  listRules(): Promise<GovernanceRuleDto[]>;
  createRule(input: CreateGovernanceRuleRequest): Promise<GovernanceRuleDto>;
  listVersions(ruleId: string): Promise<RuleVersionDto[]>;
  createVersion(
    ruleId: string,
    input: CreateRuleVersionRequest,
  ): Promise<RuleVersionDto>;
}

export function createRulesClient(transport: HttpTransport): RulesClient {
  return {
    async listRules(): Promise<GovernanceRuleDto[]> {
      const response = await transport.request<PlainListEnvelope<GovernanceRuleDto>>({
        method: "GET",
        path: "/rules",
      });
      return response.data;
    },

    async createRule(
      input: CreateGovernanceRuleRequest,
    ): Promise<GovernanceRuleDto> {
      const response = await transport.request<
        SingleEnvelope<GovernanceRuleDto>,
        CreateGovernanceRuleRequest
      >({
        method: "POST",
        path: "/rules",
        body: input,
      });
      return response.data;
    },

    async listVersions(ruleId: string): Promise<RuleVersionDto[]> {
      const response = await transport.request<PlainListEnvelope<RuleVersionDto>>({
        method: "GET",
        path: `/rules/${ruleId}/versions`,
      });
      return response.data;
    },

    async createVersion(
      ruleId: string,
      input: CreateRuleVersionRequest,
    ): Promise<RuleVersionDto> {
      const response = await transport.request<
        SingleEnvelope<RuleVersionDto>,
        CreateRuleVersionRequest
      >({
        method: "POST",
        path: `/rules/${ruleId}/versions`,
        body: input,
      });
      return response.data;
    },
  };
}


