1. packages/gov-client/src/modules/registers.ts

import { HttpTransport } from "../client/transport";

export type PublicationState =
  | "DRAFT"
  | "READY_FOR_PUBLICATION"
  | "SCHEDULED"
  | "PUBLISHED"
  | "SUPERSEDED"
  | "RETRACTED"
  | "ARCHIVED";

export interface PublicRegisterEntryDto {
  id: string;
  registerType: string;
  sourceEntityType: string;
  sourceEntityId: string;
  displayTitle: string;
  displaySummary?: string;
  publicUrlSlug?: string;
  publicationState: PublicationState;
  publishedAt?: string;
}

export interface ListPublicRegisterEntriesQuery {
  registerType?: string;
}

interface PlainListEnvelope<T> {
  data: T[];
}

export interface RegistersClient {
  listEntries(
    query?: ListPublicRegisterEntriesQuery,
  ): Promise<PublicRegisterEntryDto[]>;
}

export function createRegistersClient(
  transport: HttpTransport,
): RegistersClient {
  return {
    async listEntries(
      query?: ListPublicRegisterEntriesQuery,
    ): Promise<PublicRegisterEntryDto[]> {
      const response = await transport.request<PlainListEnvelope<PublicRegisterEntryDto>>({
        method: "GET",
        path: "/registers",
        query,
      });
      return response.data;
    },
  };
}


