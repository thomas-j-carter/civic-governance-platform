5. packages/gov-client/src/modules/audit.ts

import { HttpTransport } from "../client/transport";
import { Paginated, unwrapPaginated } from "../utils/pagination";

export type ActionType =
  | "CREATE"
  | "UPDATE"
  | "DELETE"
  | "SUBMIT"
  | "REVIEW"
  | "APPROVE"
  | "REJECT"
  | "REQUEST_INFORMATION"
  | "RESUBMIT"
  | "ASSIGN"
  | "OPEN"
  | "CLOSE"
  | "CAST"
  | "COMPUTE"
  | "CERTIFY"
  | "RATIFY"
  | "PUBLISH"
  | "ARCHIVE"
  | "REVOKE"
  | "DELEGATE"
  | "LOGIN"
  | "LOGOUT"
  | "OTHER";

export interface AuditEventDto {
  id: string;
  actionType: ActionType;
  entityType: string;
  entityId: string;
  actorPersonId?: string;
  authoritySourceType?: string;
  authoritySourceId?: string;
  ruleVersionIds?: string[];
  summary?: string;
  occurredAt: string;
}

export interface ListAuditEventsQuery {
  page?: number;
  limit?: number;
  actionType?: ActionType;
  entityType?: string;
  entityId?: string;
}

interface ListEnvelope<T> {
  data: T[];
  pagination: {
    page: number;
    limit: number;
    total: number;
    totalPages: number;
  };
}

export interface AuditClient {
  listEvents(query?: ListAuditEventsQuery): Promise<Paginated<AuditEventDto>>;
}

export function createAuditClient(transport: HttpTransport): AuditClient {
  return {
    async listEvents(
      query?: ListAuditEventsQuery,
    ): Promise<Paginated<AuditEventDto>> {
      const response = await transport.request<ListEnvelope<AuditEventDto>>({
        method: "GET",
        path: "/audit/events",
        query,
      });
      return unwrapPaginated(response);
    },
  };
}


