2. packages/gov-client/src/modules/proposals.test.ts

import { describe, expect, it, vi, beforeEach } from "vitest";
import { createProposalsClient } from "./proposals";
import type { HttpTransport } from "../client/transport";

describe("createProposalsClient", () => {
  const request = vi.fn();
  const transport: HttpTransport = {
    request,
  };

  beforeEach(() => {
    request.mockReset();
  });

  it("list() requests proposal list and unwraps pagination", async () => {
    request.mockResolvedValueOnce({
      data: [
        {
          id: "proposal-1",
          title: "Proposal One",
          proposalType: "GENERAL",
          currentStage: "DRAFT",
          createdAt: "2026-03-18T12:00:00Z",
          updatedAt: "2026-03-18T12:00:00Z",
        },
      ],
      pagination: {
        page: 1,
        limit: 20,
        total: 1,
        totalPages: 1,
      },
    });

    const client = createProposalsClient(transport);
    const result = await client.list({ stage: "DRAFT", page: 1, limit: 20 });

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/proposals",
      query: { stage: "DRAFT", page: 1, limit: 20 },
    });

    expect(result.items).toHaveLength(1);
    expect(result.items[0]?.id).toBe("proposal-1");
    expect(result.total).toBe(1);
  });

  it("get() requests a proposal detail and unwraps data", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "proposal-1",
        title: "Proposal One",
        proposalType: "GENERAL",
        currentStage: "DRAFT",
        createdAt: "2026-03-18T12:00:00Z",
        updatedAt: "2026-03-18T12:00:00Z",
      },
    });

    const client = createProposalsClient(transport);
    const result = await client.get("proposal-1");

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/proposals/proposal-1",
    });

    expect(result.id).toBe("proposal-1");
  });

  it("createDraft() posts to /proposals", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "proposal-1",
        title: "Founding Resolution",
        proposalType: "GENERAL",
        currentStage: "DRAFT",
        createdAt: "2026-03-18T12:00:00Z",
        updatedAt: "2026-03-18T12:00:00Z",
      },
    });

    const client = createProposalsClient(transport);
    const input = {
      title: "Founding Resolution",
      bodyMarkdown: "# Founding Resolution",
    } as const;

    const result = await client.createDraft(input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/proposals",
      body: input,
    });

    expect(result.title).toBe("Founding Resolution");
  });

  it("createVersion() posts to the versions endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "version-2",
        proposalId: "proposal-1",
        versionNumber: 2,
        titleSnapshot: "Updated Title",
        bodyMarkdown: "# Updated",
        createdByPersonId: "person-1",
        createdAt: "2026-03-18T12:05:00Z",
      },
    });

    const client = createProposalsClient(transport);
    const input = {
      titleSnapshot: "Updated Title",
      bodyMarkdown: "# Updated",
      changeSummary: "Clarified section 1",
    };

    const result = await client.createVersion("proposal-1", input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/proposals/proposal-1/versions",
      body: input,
    });

    expect(result.versionNumber).toBe(2);
  });

  it("setCurrentVersion() posts to the set-current-version action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "proposal-1",
        title: "Proposal One",
        proposalType: "GENERAL",
        currentStage: "DRAFT",
        currentVersionId: "version-2",
        createdAt: "2026-03-18T12:00:00Z",
        updatedAt: "2026-03-18T12:06:00Z",
      },
    });

    const client = createProposalsClient(transport);
    const input = {
      proposalVersionId: "version-2",
    };

    const result = await client.setCurrentVersion("proposal-1", input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/proposals/proposal-1/actions/set-current-version",
      body: input,
    });

    expect(result.currentVersionId).toBe("version-2");
  });

  it("submit() posts to the submit action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "proposal-1",
        title: "Proposal One",
        proposalType: "GENERAL",
        currentStage: "SUBMITTED",
        createdAt: "2026-03-18T12:00:00Z",
        updatedAt: "2026-03-18T12:07:00Z",
      },
    });

    const client = createProposalsClient(transport);
    const input = { note: "Ready for review." };

    const result = await client.submit("proposal-1", input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/proposals/proposal-1/actions/submit",
      body: input,
    });

    expect(result.currentStage).toBe("SUBMITTED");
  });

  it("assignCommittee() posts to the assign-committee action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "proposal-1",
        title: "Proposal One",
        proposalType: "GENERAL",
        currentStage: "COMMITTEE_ASSIGNED",
        createdAt: "2026-03-18T12:00:00Z",
        updatedAt: "2026-03-18T12:08:00Z",
      },
    });

    const client = createProposalsClient(transport);
    const input = { governanceBodyId: "body-1" };

    const result = await client.assignCommittee("proposal-1", input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/proposals/proposal-1/actions/assign-committee",
      body: input,
    });

    expect(result.currentStage).toBe("COMMITTEE_ASSIGNED");
  });

  it("listAmendments() requests the amendments endpoint", async () => {
    request.mockResolvedValueOnce({
      data: [
        {
          id: "amendment-1",
          proposalId: "proposal-1",
          bodyText: "Insert a new clause.",
          status: "PROPOSED",
          submittedAt: "2026-03-18T12:10:00Z",
        },
      ],
    });

    const client = createProposalsClient(transport);
    const result = await client.listAmendments("proposal-1");

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/proposals/proposal-1/amendments",
    });

    expect(result).toHaveLength(1);
    expect(result[0]?.id).toBe("amendment-1");
  });
});


