4… 3… 2… proceeding with the first unit test batch for packages/gov-client.

Batch 4 — initial unit tests

These tests assume Vitest as the test runner, which is the strongest recommendation for this TypeScript package.

1. packages/gov-client/src/client/transport.test.ts

import { describe, expect, it, vi, beforeEach, afterEach } from "vitest";
import { createHttpTransport } from "./transport";
import type { GovClientConfig } from "./config";
import { resolveGovClientConfig } from "./config";
import { GovApiError } from "./errors";

function createJsonResponse(body: unknown, init?: ResponseInit): Response {
  return new Response(JSON.stringify(body), {
    status: init?.status ?? 200,
    headers: {
      "content-type": "application/json",
      ...(init?.headers ?? {}),
    },
  });
}

describe("createHttpTransport", () => {
  const fetchMock = vi.fn<typeof fetch>();

  beforeEach(() => {
    fetchMock.mockReset();
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  function makeConfig(overrides?: Partial<GovClientConfig>) {
    return resolveGovClientConfig({
      baseUrl: "http://localhost:3002/api/v1",
      fetchImpl: fetchMock,
      ...overrides,
    });
  }

  it("sends GET requests and parses JSON responses", async () => {
    fetchMock.mockResolvedValueOnce(
      createJsonResponse({
        data: {
          id: "proposal-1",
          title: "Proposal",
        },
      }),
    );

    const transport = createHttpTransport(makeConfig());

    const result = await transport.request<{ data: { id: string; title: string } }>({
      method: "GET",
      path: "/proposals/proposal-1",
    });

    expect(fetchMock).toHaveBeenCalledTimes(1);
    expect(fetchMock.mock.calls[0]?.[0]).toBe(
      "http://localhost:3002/api/v1/proposals/proposal-1",
    );

    const init = fetchMock.mock.calls[0]?.[1];
    expect(init?.method).toBe("GET");

    expect(result.data.id).toBe("proposal-1");
    expect(result.data.title).toBe("Proposal");
  });

  it("serializes query params", async () => {
    fetchMock.mockResolvedValueOnce(createJsonResponse({ data: [] }));

    const transport = createHttpTransport(makeConfig());

    await transport.request<{ data: unknown[] }>({
      method: "GET",
      path: "/proposals",
      query: {
        page: 2,
        limit: 25,
        stage: "DRAFT",
      },
    });

    expect(fetchMock.mock.calls[0]?.[0]).toBe(
      "http://localhost:3002/api/v1/proposals?page=2&limit=25&stage=DRAFT",
    );
  });

  it("serializes JSON request bodies", async () => {
    fetchMock.mockResolvedValueOnce(
      createJsonResponse({
        data: { id: "proposal-1" },
      }),
    );

    const transport = createHttpTransport(makeConfig());

    await transport.request<{ data: { id: string } }, { title: string; bodyMarkdown: string }>({
      method: "POST",
      path: "/proposals",
      body: {
        title: "Founding Resolution",
        bodyMarkdown: "# Hello",
      },
    });

    const init = fetchMock.mock.calls[0]?.[1];
    expect(init?.method).toBe("POST");
    expect(init?.body).toBe(
      JSON.stringify({
        title: "Founding Resolution",
        bodyMarkdown: "# Hello",
      }),
    );

    const headers = init?.headers as Headers;
    expect(headers.get("content-type")).toBe("application/json");
    expect(headers.get("accept")).toBe("application/json");
  });

  it("attaches bearer token when access token provider is configured", async () => {
    fetchMock.mockResolvedValueOnce(createJsonResponse({ data: {} }));

    const transport = createHttpTransport(
      makeConfig({
        getAccessToken: async () => "token-123",
      }),
    );

    await transport.request<{ data: object }>({
      method: "GET",
      path: "/identity/me",
    });

    const init = fetchMock.mock.calls[0]?.[1];
    const headers = init?.headers as Headers;
    expect(headers.get("authorization")).toBe("Bearer token-123");
  });

  it("throws GovApiError when API returns problem details", async () => {
    fetchMock.mockResolvedValueOnce(
      createJsonResponse(
        {
          type: "https://gov-api.ardtiresociety.org/problems/invalid-state-transition",
          title: "Invalid state transition",
          status: 409,
          detail: "Proposal cannot be submitted from current stage.",
          code: "invalid_state_transition",
        },
        {
          status: 409,
          headers: {
            "x-trace-id": "trace-abc",
          },
        },
      ),
    );

    const transport = createHttpTransport(makeConfig());

    await expect(
      transport.request({
        method: "POST",
        path: "/proposals/proposal-1/actions/submit",
      }),
    ).rejects.toBeInstanceOf(GovApiError);

    try {
      await transport.request({
        method: "POST",
        path: "/proposals/proposal-1/actions/submit",
      });
    } catch (error) {
      expect(error).toBeInstanceOf(GovApiError);
      const govError = error as GovApiError;
      expect(govError.status).toBe(409);
      expect(govError.problem.code).toBe("invalid_state_transition");
      expect(govError.traceId).toBe("trace-abc");
    }
  });

  it("falls back to a generic problem when non-problem JSON error is returned", async () => {
    fetchMock.mockResolvedValueOnce(
      createJsonResponse(
        {
          message: "Something went wrong",
        },
        { status: 500 },
      ),
    );

    const transport = createHttpTransport(makeConfig());

    await expect(
      transport.request({
        method: "GET",
        path: "/identity/me",
      }),
    ).rejects.toBeInstanceOf(GovApiError);
  });

  it("preserves explicit request headers", async () => {
    fetchMock.mockResolvedValueOnce(createJsonResponse({ data: {} }));

    const transport = createHttpTransport(makeConfig());

    await transport.request({
      method: "GET",
      path: "/identity/me",
      headers: {
        "x-custom-header": "hello",
      },
    });

    const init = fetchMock.mock.calls[0]?.[1];
    const headers = init?.headers as Headers;
    expect(headers.get("x-custom-header")).toBe("hello");
  });
});


