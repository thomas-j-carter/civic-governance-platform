4. packages/gov-client/src/modules/certifications.test.ts

import { describe, expect, it, vi, beforeEach } from "vitest";
import { createCertificationsClient } from "./certifications";
import type { HttpTransport } from "../client/transport";

describe("createCertificationsClient", () => {
  const request = vi.fn();
  const transport: HttpTransport = {
    request,
  };

  beforeEach(() => {
    request.mockReset();
  });

  it("create() posts to /certifications", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "cert-1",
        ballotId: "ballot-1",
        status: "PENDING",
        quorumRuleVersionId: "rule-q-1",
        thresholdRuleVersionId: "rule-t-1",
      },
    });

    const client = createCertificationsClient(transport);
    const input = {
      ballotId: "ballot-1",
      notes: "Prepare review package.",
    };

    const result = await client.create(input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/certifications",
      body: input,
    });

    expect(result.id).toBe("cert-1");
    expect(result.status).toBe("PENDING");
  });

  it("get() requests a certification detail", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "cert-1",
        ballotId: "ballot-1",
        status: "UNDER_REVIEW",
        quorumRuleVersionId: "rule-q-1",
        thresholdRuleVersionId: "rule-t-1",
      },
    });

    const client = createCertificationsClient(transport);
    const result = await client.get("cert-1");

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/certifications/cert-1",
    });

    expect(result.status).toBe("UNDER_REVIEW");
  });

  it("certify() posts to the certify action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "cert-1",
        ballotId: "ballot-1",
        status: "CERTIFIED",
        certifiedByPersonId: "person-1",
        certifiedAt: "2026-03-18T12:40:00Z",
        quorumRuleVersionId: "rule-q-1",
        thresholdRuleVersionId: "rule-t-1",
      },
    });

    const client = createCertificationsClient(transport);
    const result = await client.certify("cert-1");

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/certifications/cert-1/actions/certify",
    });

    expect(result.status).toBe("CERTIFIED");
    expect(result.certifiedByPersonId).toBe("person-1");
  });

  it("reject() posts to the reject action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "cert-1",
        ballotId: "ballot-1",
        status: "REJECTED",
        rejectedAt: "2026-03-18T12:42:00Z",
        quorumRuleVersionId: "rule-q-1",
        thresholdRuleVersionId: "rule-t-1",
      },
    });

    const client = createCertificationsClient(transport);
    const input = {
      notes: "Threshold calculation package incomplete.",
    };

    const result = await client.reject("cert-1", input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/certifications/cert-1/actions/reject",
      body: input,
    });

    expect(result.status).toBe("REJECTED");
  });

  it("createRatification() posts to /ratifications", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "rat-1",
        proposalId: "proposal-1",
        certificationRecordId: "cert-1",
        status: "RATIFIED",
        ratifiedAt: "2026-03-18T12:45:00Z",
      },
    });

    const client = createCertificationsClient(transport);
    const input = {
      proposalId: "proposal-1",
      certificationRecordId: "cert-1",
      notes: "Ratified by competent authority.",
    };

    const result = await client.createRatification(input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/ratifications",
      body: input,
    });

    expect(result.status).toBe("RATIFIED");
  });
});


---

Recommended test runner/package additions

To support these tests, I recommend the following additions at the monorepo/package level.

packages/gov-client/package.json updates

Add:

{
  "scripts": {
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}

So the resulting scripts section becomes:

{
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}


---

Recommended next step

The strongest next step is to generate the actual file-by-file contents for apps/gov-api foundation, starting with:

route registration structure

problem-details HTTP error utilities

auth/authority middleware skeleton

identity routes

proposals routes for the first vertical slice

handler interfaces for command/query execution


That is the best next move because the client is now far enough along to support backend contract-driven implementation.
