3. packages/gov-client/src/modules/ballots.test.ts

import { describe, expect, it, vi, beforeEach } from "vitest";
import { createBallotsClient } from "./ballots";
import type { HttpTransport } from "../client/transport";

describe("createBallotsClient", () => {
  const request = vi.fn();
  const transport: HttpTransport = {
    request,
  };

  beforeEach(() => {
    request.mockReset();
  });

  it("list() requests ballots and unwraps pagination", async () => {
    request.mockResolvedValueOnce({
      data: [
        {
          id: "ballot-1",
          title: "Final Vote",
          state: "DRAFT",
        },
      ],
      pagination: {
        page: 1,
        limit: 20,
        total: 1,
        totalPages: 1,
      },
    });

    const client = createBallotsClient(transport);
    const result = await client.list({ state: "DRAFT" });

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/ballots",
      query: { state: "DRAFT" },
    });

    expect(result.items[0]?.id).toBe("ballot-1");
  });

  it("create() posts to /ballots", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "ballot-1",
        proposalId: "proposal-1",
        title: "Final Vote",
        state: "DRAFT",
      },
    });

    const client = createBallotsClient(transport);
    const input = {
      proposalId: "proposal-1",
      title: "Final Vote",
    };

    const result = await client.create(input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/ballots",
      body: input,
    });

    expect(result.id).toBe("ballot-1");
  });

  it("open() posts to the open action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "ballot-1",
        title: "Final Vote",
        state: "OPEN",
        openedAt: "2026-03-18T12:15:00Z",
      },
    });

    const client = createBallotsClient(transport);
    const result = await client.open("ballot-1");

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/ballots/ballot-1/actions/open",
    });

    expect(result.state).toBe("OPEN");
  });

  it("close() posts to the close action endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "ballot-1",
        title: "Final Vote",
        state: "CLOSED",
        closedAt: "2026-03-18T12:20:00Z",
      },
    });

    const client = createBallotsClient(transport);
    const result = await client.close("ballot-1");

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/ballots/ballot-1/actions/close",
    });

    expect(result.state).toBe("CLOSED");
  });

  it("castVote() posts to the votes endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        id: "vote-1",
        ballotId: "ballot-1",
        memberId: "member-1",
        choice: "YES",
        castAt: "2026-03-18T12:18:00Z",
      },
    });

    const client = createBallotsClient(transport);
    const input = { choice: "YES" as const };

    const result = await client.castVote("ballot-1", input);

    expect(request).toHaveBeenCalledWith({
      method: "POST",
      path: "/ballots/ballot-1/votes",
      body: input,
    });

    expect(result.choice).toBe("YES");
  });

  it("getTally() requests the tally endpoint", async () => {
    request.mockResolvedValueOnce({
      data: {
        ballotId: "ballot-1",
        yesCount: 10,
        noCount: 2,
        abstainCount: 1,
        totalCount: 13,
        quorumMet: true,
        thresholdMet: true,
        computedAt: "2026-03-18T12:30:00Z",
      },
    });

    const client = createBallotsClient(transport);
    const result = await client.getTally("ballot-1");

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/ballots/ballot-1/tally",
    });

    expect(result.totalCount).toBe(13);
    expect(result.quorumMet).toBe(true);
  });

  it("getEligibility() requests the eligibility endpoint", async () => {
    request.mockResolvedValueOnce({
      data: [
        {
          ballotId: "ballot-1",
          memberId: "member-1",
          eligibilityStatus: "ELIGIBLE",
          snapshotAt: "2026-03-18T12:15:00Z",
        },
      ],
    });

    const client = createBallotsClient(transport);
    const result = await client.getEligibility("ballot-1");

    expect(request).toHaveBeenCalledWith({
      method: "GET",
      path: "/ballots/ballot-1/eligibility",
    });

    expect(result[0]?.eligibilityStatus).toBe("ELIGIBLE");
  });
});


