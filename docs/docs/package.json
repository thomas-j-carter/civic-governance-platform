{
  "name": "@repo/public-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "docusaurus build",
    "clear": "docusaurus clear",
    "deploy": "docusaurus deploy",
    "dev": "docusaurus start --host 0.0.0.0 --port 3005",
    "docusaurus": "docusaurus",
    "generate:openapi": "tsx scripts/build-openapi-docs.ts",
    "prebuild": "pnpm validate && pnpm sync:public && pnpm generate:openapi",
    "serve": "docusaurus serve --port 3006",
    "swizzle": "docusaurus swizzle",
    "sync:public": "tsx scripts/sync-public-docs.ts",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-frontmatter.ts",
    "version:cut": "docusaurus docs:version",
    "write-heading-ids": "docusaurus write-heading-ids",
    "write-translations": "docusaurus write-translations"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tinacms": "^2.7.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "typescript": "~5.6.2",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
