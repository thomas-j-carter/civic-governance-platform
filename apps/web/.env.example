VITE_AUTH_CLIENT_ID=ardtire-web

# CMS / content
VITE_CMS_BASE_URL=https://cms.ardtiresociety.org

# Observability
VITE_SENTRY_DSN=

# Feature flags
VITE_ENABLE_ADMIN=true
VITE_ENABLE_MEMBER=true
VITE_ENABLE_GOVERNANCE=true