# Public app environment
VITE_APP_NAME=Ardtire Society
VITE_APP_ENV=development
VITE_PUBLIC_BASE_URL=http://localhost:3000

# Backend/API
VITE_API_BASE_URL=http://localhost:3002

# Auth / identity
VITE_AUTH_BASE_URL=https://id.ardtiresociety.org
